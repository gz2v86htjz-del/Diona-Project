extends layout
include mixins/mixins.pug

//- page1Tables / page2Tables are computed in the route (server.js),
//- which is the reason each is already the right slice of the
//- shared EXPENSE_TABLES config for this page.

block content
  form#claimForm(action="/medical-travel/save" method="post")
    input(type="hidden" name="sample" value=activeSample)
    .sheet-stack

      //- ============================= SHEET 1 =============================
      section.sheet
        +docHeader('Medical & Travel Expense Request', claim.claimNo)

        p.intro-line
          span.worker-name= claim.workerName
          |  requested reimbursement for the following medical and/or travel expenses:

        each table in page1Tables
          +expenseTable(table, claim.rows[table.key])

        +docFooter(claim.workerAppId, claim.submitted, `Page 1 of ${totalPages}`)

      //- ============================= SHEET 2 =============================
      section.sheet
        each table in page2Tables
          +expenseTable(table, claim.rows[table.key])

        hr(style="border:none;border-top:1px solid #ccc;margin:24px 0 14px;")
        +privacyRow(claim.privacyAck)

        +docFooter(claim.workerAppId, claim.submitted, `Page 2 of ${totalPages}`)
